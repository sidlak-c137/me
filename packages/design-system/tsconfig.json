{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"isolatedModules": true,
		"resolveJsonModule": true,
		"allowJs": true,
		"checkJs": true,
		"sourceMap": true,
		"declaration": true,
		"rootDir": "src/lib",
		"outDir": "dist"
	},
	"include": ["src/**/*"]
}
